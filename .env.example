# App
APP_NAME="AI Chat Service"
DEBUG=false

# Database  (individual fields — DATABASE_URL is assembled by the app)
# When running locally (without Docker):  POSTGRES_HOST=localhost
# When running with docker-compose:       POSTGRES_HOST is overridden to "db"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=chatdb
DB_ECHO=false

# LLM — set OPENAI_API_KEY (preferred) OR GEMINI_API_KEY (fallback), not both

# OpenAI  →  https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini  →  https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.5-flash
